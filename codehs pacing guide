        // Render State Standards Matrix Component
        function renderStandardsTable() {
            const tbody = document.getElementById('standards-table-body');
            tbody.innerHTML = Object.keys(standardDescriptions).map(code => {
                const matchedWeeks = syllabusData.filter(w => w.standards.includes(code)).map(w => `W${w.week}`);
                return `
                    <tr class="hover:bg-slate-50/70 transition-colors">
                        <td class="px-4 py-3 font-bold text-indigo-600 border-r border-slate-100 whitespace-nowrap">TN-${code}</td>
                        <td class="px-4 py-3 text-slate-600 max-w-md">${standardDescriptions[code]}</td>
                        <td class="px-4 py-3 whitespace-nowrap">
                            ${matchedWeeks.length ? matchedWeeks.map(w => `<span class="inline-block bg-slate-100 text-slate-700 text-[10px] font-bold px-1.5 py-0.5 rounded mr-1 border border-slate-200">${w}</span>`).join('') : '<span class="text-slate-300 font-normal">Elective Pathway</span>'}
                        </td>
                    </tr>
                `;
            }).join('');
        }

        // Real-Time Content Filter Mechanics
        function filterCurriculum() {
            const query = document.getElementById('search').value.toLowerCase();
            const cards = document.getElementsByClassName('week-card');
            
            for (let card of cards) {
                const searchContent = card.getAttribute('data-text');
                if (searchContent.includes(query)) {
                    card.style.display = "block";
                } else {
                    card.style.display = "none";
                }
            }
        }

        // View Layout Tab Control
        function switchTab(target) {
            const btnCal = document.getElementById('tab-calendar');
            const btnStd = document.getElementById('tab-standards');
            const viewCal = document.getElementById('view-calendar');
            const viewStd = document.getElementById('view-standards');

            if (target === 'calendar') {
                btnCal.className = "text-xs font-semibold py-1.5 px-3 rounded-md transition-all bg-white text-slate-900 shadow-xs";
                btnStd.className = "text-xs font-semibold py-1.5 px-3 rounded-md transition-all text-slate-600 hover:text-slate-900";
                viewCal.classList.remove('hidden');
                viewStd.classList.add('hidden');
            } else {
                btnStd.className = "text-xs font-semibold py-1.5 px-3 rounded-md transition-all bg-white text-slate-900 shadow-xs";
                btnCal.className = "text-xs font-semibold py-1.5 px-3 rounded-md transition-all text-slate-600 hover:text-slate-900";
                viewStd.classList.remove('hidden');
                viewCal.classList.add('hidden');
            }
        }

        // Local Storage State Progress Sync Controls
        function updateProgress() {
            const total = syllabusData.length;
            let checkedCount = 0;
            let savedState = {};

            syllabusData.forEach(w => {
                const cb = document.getElementById(`check-w${w.week}`);
                savedState[`w${w.week}`] = cb.checked;
                if (cb.checked) checkedCount++;
            });

            localStorage.setItem('tn_cs_foundations_progress', JSON.stringify(savedState));

            const percent = Math.round((checkedCount / total) * 100);
            document.getElementById('progress-percent').innerText = `${percent}%`;
            document.getElementById('progress-bar').style.width = `${percent}%`;
            document.getElementById('progress-fraction').innerText = `${checkedCount} / ${total} Weeks`;
        }

        function loadProgressState() {
            const saved = localStorage.getItem('tn_cs_foundations_progress');
            if (saved) {
                const state = JSON.parse(saved);
                syllabusData.forEach(w => {
                    if (state[`w${w.week}`]) {
                        document.getElementById(`check-w${w.week}`).checked = true;
                    }
                });
                updateProgress();
            }
        }

        // Initial Boot sequence
        window.onload = function() {
            renderCalendar();
            renderStandardsTable();
        };
    </script>
</body>
</html>
